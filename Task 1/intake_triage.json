    {
      "parameters": {
        "jsCode": "// Loop over each item coming from Google Sheets\nfor (const item of $input.all()) {\n  \n  // List of fields that should be boolean (true/false)\n  const booleanFields = ['has_children', 'owns_property', 'has_business'];\n\n  booleanFields.forEach(field => {\n    // If field is empty string, undefined, or null, set to false\n    // Otherwise, convert to actual boolean if it's a string like \"true\"\n    if (item.json[field] === \"\" || item.json[field] === undefined || item.json[field] === null) {\n      item.json[field] = false;\n    } else {\n      // Ensure existing \"true\"/\"false\" strings or numbers are cast to proper booleans\n      item.json[field] = Boolean(item.json[field]);\n    }\n  });\n\n  // Ensure age is an integer as required by the brief \n  if (item.json.age) {\n    item.json.age = parseInt(item.json.age, 10);\n  }\n}\n\nreturn $input.all();"
      },
